  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}",
      "env": {},
      "args": ["serve"]
    },

    {
      "name": "Import Project",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}",
      "env": {},
      "args": ["project", "create", "debug", "./lego/chain-gun.csv"]
    },

    {
      "name": "Import Kit",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}",
      "env": {
      },
      "args": ["kit", "import", "75976-1"]
    },

    {
      "name": "Rebuild Views",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}",
      "env": {},
      "args": ["eventstore", "view", "rebuild"]
    }
  ]
}
